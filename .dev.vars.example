# Copy to .dev.vars — consumed by the Cloudflare runtime (miniflare) during
# `next dev` and `pnpm preview`, exposing these via getCloudflareContext().
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_FALLBACK_MODELS=anthropic/claude-sonnet-4.6,openai/gpt-5.5
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
