# Copy to .env.local for `next dev`. NEXT_PUBLIC_* are inlined into the
# client bundle at build time, so they must be present when building too.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. In `next dev` these are read from process.env; in production
# set them as Cloudflare secrets/vars (see README).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
