# Copy to .env.local for `next dev`. NEXT_PUBLIC_* are inlined into the
# client bundle at build time, so they must be present when building too.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. In `next dev` these are read from process.env; in production
# set them as Cloudflare secrets/vars (see README).
OPENROUTER_API_KEY=
# Primary model. Defaults to google/gemini-3-flash-preview if unset.
OPENROUTER_MODEL=google/gemini-3-flash-preview
# Ordered fallbacks (comma-separated). OpenRouter tries these when the primary
# is down or rate-limited. Defaults to anthropic/claude-sonnet-4.6,openai/gpt-5.5.
OPENROUTER_FALLBACK_MODELS=anthropic/claude-sonnet-4.6,openai/gpt-5.5
